---
import siteConfig from "../site.config";
import Hamburger from "./Hamburger.astro";
import SiteIdentity from "./SiteIdentity.astro";
import NavLinks from "./NavLinks.astro";
import { withBase } from "../utils/helpers";
const { activePage } = Astro.props;
---

<header>
  <nav class="w-full font-light">
    <a href={withBase("/")}><SiteIdentity /></a>
    <div class="hidden sm:flex sm:gap-8">
      <NavLinks activePage={activePage} links={siteConfig.headerNavLinks} />
    </div>
    <Hamburger />
  </nav>
  <div
    id="mobile-links"
    class="mobile-links font-light"
  >
    <button class="close-menu cursor-pointer" aria-label="Close navigation menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <NavLinks
      activePage={activePage}
      links={siteConfig.headerNavLinks}
      isMobileLink={true}
    />
  </div>
</header>
<script is:inline>
  function setupMobileNav() {
    const hamburger = document.querySelector("#hamburger-menu");
    const closeBtn = document.querySelector(".close-menu");
    const mobileLinks = document.querySelector("#mobile-links");

    if (hamburger && mobileLinks) {
      hamburger.addEventListener("click", function () {
        mobileLinks.classList.add("is-open");
      });
    }

    if (closeBtn && mobileLinks) {
      closeBtn.addEventListener("click", function () {
        mobileLinks.classList.remove("is-open");
      });
    }

    if (mobileLinks) {
      mobileLinks.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", function () {
          mobileLinks.classList.remove("is-open");
        });
      });
    }
  }

  setupMobileNav();
</script>

<style>
  .mobile-links {
    display: none;
  }

  .mobile-links.is-open {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    z-index: 30;
    display: flex;
    width: min(20rem, calc(100vw - 2rem));
    flex-direction: column;
    gap: 1rem;
    border: 1px solid rgb(10 45 68 / 0.12);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.97);
    box-shadow: 0 16px 36px rgb(10 45 68 / 0.16);
    padding: 1rem 1.25rem 1.25rem;
  }

  @media (min-width: 640px) {
    .mobile-links,
    .mobile-links.is-open {
      display: none;
    }
  }
</style>
