---
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
---

<MainLayout activePage="support" pageTitle={siteConfig.title + " | Support"}>
  <div class="page-content my-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-balance mb-4 text-left">
      Support the MCRI
    </h1>
    <p class="kanit-light text-left leading-relaxed mb-12 max-w-3xl text-lg">
      Your support empowers the next generation of tech leaders in Zimbabwe and helps us
      create lasting change through education, opportunity, and innovation.
    </p>

    <!-- Impact Statement -->
    <div class="mb-16 rounded-2xl border border-primary-blue/20 bg-gradient-to-br from-primary-blue/10 to-primary-blue/5 p-8">
      <div class="flex items-start gap-6">
        <div class="text-5xl flex-shrink-0">💡</div>
        <div>
          <h2 class="text-2xl font-bold mb-3">Why Your Support Matters</h2>
          <p class="kanit-light leading-relaxed text-lg mb-4">
            The MCRI is more than a school—it's a gateway to opportunity for young Zimbabweans
            who dream of careers in technology. Every contribution directly impacts students' lives,
            helping break down barriers and create pathways to meaningful employment.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
            <div class="rounded-xl bg-white/70 p-4 text-center">
              <div class="text-3xl font-bold text-primary-blue">30</div>
              <div class="text-sm kanit-light mt-1">Zimbabweans Employed by 2026</div>
            </div>
            <div class="rounded-xl bg-white/70 p-4 text-center">
              <div class="text-3xl font-bold text-primary-blue">2,000</div>
              <div class="text-sm kanit-light mt-1">Students Learning by 2026</div>
            </div>
            <div class="rounded-xl bg-white/70 p-4 text-center">
              <div class="text-3xl font-bold text-primary-blue">50%+</div>
              <div class="text-sm kanit-light mt-1">Women Enrollment</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Ways to Support -->
    <h2 class="text-2xl sm:text-3xl font-bold text-balance mb-8 text-left">
      Ways to Support
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">

      <!-- Scholarship Program -->
      <div class="support-card p-8 rounded-2xl border border-gray-500/20 hover:border-primary-blue transition-all">
        <div class="flex items-start gap-4 mb-4">
          <div class="text-4xl">🎓</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">Scholarship Program</h3>
            <p class="kanit-light leading-relaxed mb-4">
              In Zimbabwe, families must pay for the equivalent of Junior and Senior years of high school.
              Many talented young women are left behind simply due to cost.
            </p>
            <p class="kanit-light leading-relaxed">
              <strong>Your scholarship donations ensure that young women aren't excluded from their
              education</strong> and can continue their journey to the MCRI.
            </p>
          </div>
        </div>
      </div>

      <!-- Equipment & Technology -->
      <div class="support-card p-8 rounded-2xl border border-gray-500/20 hover:border-primary-blue transition-all">
        <div class="flex items-start gap-4 mb-4">
          <div class="text-4xl">💻</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">Equipment & Technology</h3>
            <p class="kanit-light leading-relaxed mb-4">
              Every student needs access to modern technology to succeed in their technical curriculum.
              From MacBooks to development tools, technology access is essential.
            </p>
            <p class="kanit-light leading-relaxed">
              <strong>Equipment donations help us provide students with the tools they need</strong>
              to master Swift, Jamf, and other cutting-edge technologies.
            </p>
          </div>
        </div>
      </div>

      <!-- Mentorship & Expertise -->
      <div class="support-card p-8 rounded-2xl border border-gray-500/20 hover:border-primary-blue transition-all">
        <div class="flex items-start gap-4 mb-4">
          <div class="text-4xl">🤝</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">Mentorship & Expertise</h3>
            <p class="kanit-light leading-relaxed mb-4">
              Industry professionals can share their knowledge through guest lectures, workshops,
              or ongoing mentorship relationships with our students.
            </p>
            <p class="kanit-light leading-relaxed">
              <strong>Your time and expertise help bridge the gap between education and real-world
              experience</strong>, preparing students for successful careers.
            </p>
          </div>
        </div>
      </div>

      <!-- Employment Opportunities -->
      <div class="support-card p-8 rounded-2xl border border-gray-500/20 hover:border-primary-blue transition-all">
        <div class="flex items-start gap-4 mb-4">
          <div class="text-4xl">💼</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">Employment Opportunities</h3>
            <p class="kanit-light leading-relaxed mb-4">
              Companies like Jamf, Mains'l, and Tradition Bank are already employing MCRI graduates
              remotely from Zimbabwe, creating sustainable career paths.
            </p>
            <p class="kanit-light leading-relaxed">
              <strong>Partner with us to hire talented graduates</strong> and build diverse,
              global remote teams with skilled professionals.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- The Impact -->
    <div class="mb-12 p-8 rounded-2xl border border-gray-500/15 bg-gradient-to-br from-transparent to-gray-500/5">
      <h2 class="text-2xl font-bold mb-6 text-center">The Ripple Effect of Your Support</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-3">🌱</div>
          <h3 class="font-semibold mb-2">Early Intervention</h3>
          <p class="kanit-light text-sm">
            Support at the high school level ensures talented students reach the MCRI
          </p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🚀</div>
          <h3 class="font-semibold mb-2">Career Launch</h3>
          <p class="kanit-light text-sm">
            MCRI graduates secure remote tech jobs, earning competitive salaries in Zimbabwe
          </p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🌍</div>
          <h3 class="font-semibold mb-2">Community Impact</h3>
          <p class="kanit-light text-sm">
            Employed graduates support their families and inspire the next generation
          </p>
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="rounded-2xl border border-primary-blue/30 bg-gradient-to-br from-primary-blue/10 to-transparent p-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Ready to Make a Difference?</h2>
      <p class="kanit-light text-lg mb-6 max-w-2xl mx-auto">
        Contact the Jamf Community Education Initiatives team to discuss scholarship donations,
        equipment contributions, mentorship opportunities, or hiring partnerships.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://www.linkedin.com/company/matterinnovationcentre/"
          target="_blank"
          rel="noreferrer"
          class="button-link space-btn-filled inline-flex items-center gap-2"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>

  </div>
</MainLayout>

<style>
  .support-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .support-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
</style>
